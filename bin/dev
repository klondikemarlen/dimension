#!/usr/bin/env ruby

require_relative "./github_api"
require_relative "./pull-request-editor"
require "net/http"
require "uri"

require "socket"

class DevHelper
  # Support dashes in command names
  COMMAND_TO_METHOD = {
    "ts-node" => :ts_node,
    "branch-from" => :branch_from,
    "description-from" => :description_from,
    "check-types" => :check_types,
    "bash-completions" => :bash_completions,
    "plantuml-to-png" => :plantuml_to_png,
    "edit-pr" => :edit_pr,
  }
  METHOD_TO_COMMAND = COMMAND_TO_METHOD.invert

  REPLACE_PROCESS = "replace_process"
  WAIT_FOR_PROCESS = "wait_for_process"

  PORT_ENV_FILE = ".dev-ports.env"
  BOOT_TIMEOUT_SECONDS = 30
  PORT_ENV_KEYS = %w[
    DIMENSION_API_PORT
    DIMENSION_API_DEBUG_PORT
    DIMENSION_WEB_PORT
    DIMENSION_PLANTUML_PORT
  ].freeze
  SERVICE_PORT_MAP = {
    "DIMENSION_API_PORT" => ["api", 3000],
    "DIMENSION_API_DEBUG_PORT" => ["api", 9229],
    "DIMENSION_WEB_PORT" => ["web", 5173],
    "DIMENSION_PLANTUML_PORT" => ["plantuml", 8080],
  }.freeze

  # External Interface
  def self.call(*args)
    new.call(*args)
  end

  # Core logic
  def call(*args, **kwargs)
    command = args[0]
    method = COMMAND_TO_METHOD.fetch(command, command)
    if args.length.positive? && respond_to?(method)
      public_send(method, *args.drop(1), **kwargs)
    else
      compose(*args, **kwargs)
    end
  end

  def compose(*args, **kwargs)
    command = compose_command(*args, **kwargs)
    puts "Running: #{command}" unless kwargs[:slient]

    case kwargs[:execution_mode]
    when WAIT_FOR_PROCESS
      wait_for_process_with_logging(command)
    else
      exec(command)
    end
  end

  # Primary command wrappers
  def build(*args, **kwargs)
    ensure_development_ports!
    compose(*%w[build], *args, **kwargs)
  end

  def run(*args, **kwargs)
    ensure_development_ports!
    compose(*%w[run --rm], *args, **kwargs)
  end

  def up(*args, **kwargs)
    ensure_development_ports!
    compose(*%w[up --remove-orphans], *args, **kwargs)
  end

  def down(*args, **kwargs)
    compose(*%w[down --remove-orphans], *args, **kwargs)
  end

  def logs(*args, **kwargs)
    compose(*%w[logs -f], *args, **kwargs)
  end


  def ps(*args, **kwargs)
    compose(*%w[ps], *args, **kwargs)
  end

  # Custom helpers
  def api(*args, **kwargs)
    run(*%w[api], *args, **kwargs)
  end

  def web(*args, **kwargs)
    run(*%w[web], *args, **kwargs)
  end

  def desktop(*args)
    ensure_desktop_renderer!

    Dir.chdir(project_root) do
      exec("npm", "run", "desktop", "--", *args)
    end
  end

  def boot(*args)
    desktop(*args)
  end

  def check_types(*args, **kwargs)
    run(*%w[api npm run check-types], *args, **kwargs)
  end

  def test(*args, **kwargs)
    service = args[0]
    if service == "api"
      test_api(*args.drop(1), **kwargs)
    elsif service == "web"
      test_web(*args.drop(1), **kwargs)
    else
      test_api(*args, **kwargs)
    end
  end

  def test_api(*args, **kwargs)
    reformat_project_relative_path_filter_for_vitest!(args, "api/")
    run(*%w[test_api npm run test], *args, **kwargs)
  end

  def test_web(*args, **kwargs)
    reformat_project_relative_path_filter_for_vitest!(args, "web/")
    run(*%w[test_web npm run test], *args, **kwargs)
  end

  def psql(*args, **kwargs)
    # TODO: use environment variables for this instead
    db(*%w[psql "postgresql://app:itsallgood@localhost:5432/travel_development"], *args, **kwargs)
  end

  def db(*args, **kwargs)
    compose(*%w[exec db], *args, **kwargs)
  end

  def debug
    api_container_id = container_id("api")
    puts "Waiting for breakpoint to trigger..."
    puts "'ctrl-c' to exit."
    command = "docker attach --detach-keys ctrl-c #{api_container_id}"
    puts "Running: #{command}"
    exec(command)
    exit 0
  end

  def npm(*args, **kwargs)
    run(*%w[api npm], *args, **kwargs)
  end

  def ts_node(*args, **kwargs)
    run(*%w[api npm run ts-node], *args, **kwargs)
  end

  def knex(*args, **kwargs)
    if RUBY_PLATFORM =~ /linux/
      run(*%w[api npm run knex], *args, execution_mode: WAIT_FOR_PROCESS, **kwargs)

      file_or_directory = "#{project_root}/api/src/db/migrations"
      exit(0) unless take_over_needed?(file_or_directory)

      ownit file_or_directory
    else
      run(*%w[api npm run knex], *args, **kwargs)
    end
  end

  def migrate(*args, **kwargs)
    action = args[0]
    knex("migrate:#{action}", *args.drop(1), **kwargs)
  end

  def seed(*args, **kwargs)
    action = args[0]
    knex("seed:#{action}", *args.drop(1), **kwargs)
  end

  ##
  # Generates and checks out a new branch based on the GitHub issue URL.
  # Example:
  #   dev branch-from https://github.com/icefoganalytics/travel-authorization/issues/218
  #
  # Produces:
  #   git checkout -b issue-218/switch-test-suite-from-jest-to-vitest
  def branch_from(github_issue_url, *args, **kwargs)
    branch_name = GithubApi.build_branch_name(github_issue_url)
    system("git checkout -b #{branch_name}")
  end

  ##
  # Fetches the description of a GitHub issue and prints it to the console in markdown format.
  # Example:
  #   dev description-from https://github.com/icefoganalytics/travel-authorization/issues/218
  #
  # Produces:
  #   ... a bunch of markdown text ...
  def description_from(github_issue_url, *args, **kwargs)
    description = GithubApi.fetch_issue_body(github_issue_url)
    puts description
  end

  ##
  # Edits the description of a pull request.
  # Example:
  #   dev edit-pr https://github.com/icefoganalytics/travel-authorization/pull/218
  def edit_pr(pull_request_url, *args, **kwargs)
    PullRequestEditor.edit_pull_request_description(pull_request_url, *args, **kwargs)
    exit(0)
  end

  def ownit(*args, **kwargs)
    file_or_directory = args[0]
    raise ScriptError, "Must provide a file or directory path." if file_or_directory.nil?

    if RUBY_PLATFORM =~ /linux/
      puts "Take ownership of the file or directory? #{file_or_directory}"
      exec("sudo chown -R #{user_id}:#{group_id} #{file_or_directory}")
    else
      raise NotImplementedError, "Not implement for platform #{RUBY_PLATFORM}"
    end
  end

  def plantuml_to_png(*args, **kwargs)
    file_path = args.pop
    raise ScriptError, "Must provide a file path." if file_path.nil?

    png_path = file_path.gsub(/\.(wsd|pu|puml|plantuml|uml)$/, ".png")
    plantuml_port = development_port("DIMENSION_PLANTUML_PORT", "59999")

    command = <<~BASH
      curl #{args.join(" ")} \
        --data-binary @'#{file_path}' \
        http://localhost:#{plantuml_port}/png > '#{png_path}'
    BASH

    puts "Running: #{command}"
    exec(command)
  end

  def bash_completions
    completions =
      public_methods(false)
        .reject { |word| %i[call].include?(word) }
        .map { |word| METHOD_TO_COMMAND.fetch(word, word) }
    puts completions
  end

  private

  def wait_for_process_with_logging(command)
    IO.popen("#{command} 2>&1") do |io|
      until io.eof?
        line = io.gets
        puts line
      end
    end
  end

  def container_id(container_name, *args, **kwargs)
    command = compose_command(*%w[ps -q], container_name, *args, **kwargs)
    puts "Running: #{command}"
    id_of_container = `#{command}`.chomp
    puts "Container id is: #{id_of_container}"
    id_of_container
  end

  def service_running?(container_name)
    ps(*%w[-q --status=running], execution_mode: WAIT_FOR_PROCESS, slient: true) != ""
  end

  def compose_command(*args, **kwargs)
    environment = kwargs.fetch(:environment, "development")
    env_file = File.exist?(port_env_file_path) ? "--env-file #{port_env_file_path}" : nil
    "cd #{project_root} && docker compose #{env_file} -f docker-compose.#{environment}.yml #{args.join(" ")}"
  end

  def project_root
    @project_root ||= File.absolute_path("#{__dir__}/..")
  end

  def ensure_development_ports!
    current_ports = read_port_environment

    if compose_project_running?
      discovered_ports = discover_running_service_ports

      if discovered_ports.any?
        current_ports = current_ports.merge(discovered_ports)
        missing_keys = PORT_ENV_KEYS.reject { |key| current_ports[key] }

        if missing_keys.any?
          current_ports.merge!(allocate_free_ports(missing_keys))
          puts "Recreated missing development ports from running services in #{port_env_file_path}: #{missing_keys.join(", ")}"
        else
          puts "Synchronized development ports from running services in #{port_env_file_path}"
        end

        current_ports["LOCAL_UID"] = user_id
        current_ports["LOCAL_GID"] = group_id
        persist_development_ports(current_ports)
        return
      end
    end

    if PORT_ENV_KEYS.all? { |key| current_ports.key?(key) } && persisted_development_ports_available?(current_ports)
      current_ports["LOCAL_UID"] = user_id
      current_ports["LOCAL_GID"] = group_id
      persist_development_ports(current_ports)
      puts "Using existing development ports and host UID/GID in #{port_env_file_path}"
      return
    end

    assignments = allocate_free_ports(PORT_ENV_KEYS)
    assignments["LOCAL_UID"] = user_id
    assignments["LOCAL_GID"] = group_id

    persist_development_ports(assignments)
    puts "Wrote development ports and host UID/GID to #{port_env_file_path}"
  end

  def discover_running_service_ports
    SERVICE_PORT_MAP.each_with_object({}) do |(key, details), discovered|
      service_name, container_port = details
      container_id = `#{compose_command(*%w[ps -q], service_name, environment: "development")}`.strip
      next if container_id.empty?

      container_port_mappings = `docker port #{container_id} #{container_port}/tcp`
      container_port_mappings.lines.each do |line|
        if (match = line.strip.match(/:(\d+)$/))
          discovered[key] = match[1]
          break
        end
      end
    end
  end

  def allocate_free_ports(keys)
    return {} if keys.empty?

    servers = keys.map { TCPServer.new("127.0.0.1", 0) }
    keys.zip(servers.map { |server| server.addr[1] }).to_h
  ensure
    servers&.each(&:close)
  end

  def read_port_environment
    return {} unless File.exist?(port_env_file_path)

    File.readlines(port_env_file_path).each_with_object({}) do |line, env|
      key, value = line.strip.split("=", 2)
      next unless key && value
      env[key] = value
    end
  end

  def persist_development_ports(ports)
    File.write(
      port_env_file_path,
      (PORT_ENV_KEYS + %w[LOCAL_UID LOCAL_GID]).map do |key|
        "#{key}=#{ports[key]}"
      end.join("\n") + "\n",
    )
  end

  def port_env_file_path
    "#{project_root}/#{PORT_ENV_FILE}"
  end

  def development_port(key, fallback)
    return ENV.fetch(key) if ENV.key?(key)

    if File.exist?(port_env_file_path)
      File.readlines(port_env_file_path).each do |line|
        env_key, value = line.strip.split("=", 2)
        return value if env_key == key && value && !value.empty?
      end
    end

    fallback
  end

  def compose_project_running?
    command = compose_command(*%w[ps -q --status=running], environment: "development")
    !`#{command}`.strip.empty?
  end

  def persisted_development_ports_available?(ports = nil)
    values = ports || read_port_environment
    persisted_ports = PORT_ENV_KEYS.filter_map { |key| values[key].to_i if values[key] }
    return false if persisted_ports.length != PORT_ENV_KEYS.length

    persisted_ports.length == persisted_ports.uniq.length && persisted_ports.all? { |port| port_available?(port) }
  end

  def port_available?(port)
    server = TCPServer.new("127.0.0.1", port)
    true
  rescue Errno::EADDRINUSE
    false
  ensure
    server&.close
  end

  def ensure_desktop_renderer!
    Dir.chdir(project_root) do
      command = ["npm", "run", "build:desktop"]
      puts "Running: #{command.join(" ")}"
      raise ScriptError, "Dimension desktop renderer failed to build." unless system(*command)
    end
  end

  def start_development_services!
    command = compose_command(*%w[up -d --remove-orphans])
    puts "Running: #{command}"
    raise ScriptError, "Dimension services failed to start." unless system(command)
  end

  def web_origin
    "http://127.0.0.1:#{development_port("DIMENSION_WEB_PORT", 58501)}"
  end


  def wait_for_web_renderer!
    target = web_origin()
    uri = URI(target)
    deadline = Process.clock_gettime(Process::CLOCK_MONOTONIC) + BOOT_TIMEOUT_SECONDS

    loop do
      begin
        remaining = deadline - Process.clock_gettime(Process::CLOCK_MONOTONIC)
        break if remaining <= 0

        timeout_seconds = [remaining, 1].min
        response = Net::HTTP.start(
          uri.host,
          uri.port,
          open_timeout: timeout_seconds,
          read_timeout: timeout_seconds,
        ) do |http|
          http.get(uri.request_uri)
        end

        return if response.is_a?(Net::HTTPSuccess)
      rescue Errno::ECONNREFUSED, Errno::EHOSTUNREACH, Errno::ECONNRESET, EOFError, Net::OpenTimeout, Net::ReadTimeout, SocketError
        # Vite has not started yet.
      end

      break if Process.clock_gettime(Process::CLOCK_MONOTONIC) >= deadline

      sleep 0.25
    end

    raise ScriptError, "Dimension web renderer was not ready at #{target} after #{BOOT_TIMEOUT_SECONDS} seconds."
  end

  def take_over_needed?(file_or_directory)
    files_owned_by_others =
      system("find #{file_or_directory} -not -user #{user_id} -print -quit | grep -q .")
    files_owned_by_others
  end

  def user_id
    unless RUBY_PLATFORM =~ /linux/
      raise NotImplementedError, "Not implement for platform #{RUBY_PLATFORM}"
    end

    `id -u`.strip
  end

  def group_id
    unless RUBY_PLATFORM =~ /linux/
      raise NotImplementedError, "Not implement for platform #{RUBY_PLATFORM}"
    end

    `id -g`.strip
  end

  def reformat_project_relative_path_filter_for_vitest!(args, prefix)
    if args.length.positive? && args[0].start_with?(prefix)
      src_path_prefix = "#{prefix}src/"
      test_path_regex = Regexp.escape(prefix)
      src_path_regex = Regexp.escape(src_path_prefix)

      if args[0].start_with?(src_path_prefix)
        # TODO: handle other file types
        args[0] = args[0].gsub(/^#{src_path_regex}/, "tests/").gsub(/\.ts$/, ".test.ts")
      else
        args[0] = args[0].gsub(/^#{test_path_regex}/, "")
      end

      puts "Reformatted path filter from project relative to service relative for vitest."
    end
  end
end

# Only execute main function when file is executed
DevHelper.call(*ARGV) if $PROGRAM_NAME == __FILE__

